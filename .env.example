# Database
DATABASE_URL="file:./dev.db"

# JWT Secret (change this to a secure random string in production)
JWT_SECRET_KEY=""

# Gemini AI (optional - for auto-grading)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=""

# Firebase Authentication (for Google Sign-in)
# Get your Web API Key from: Firebase Console > Project Settings > General > Your apps > Web app > SDK setup and configuration
FIREBASE_WEB_API_KEY=""

# Client-side Firebase Config (paste from Firebase Console)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
